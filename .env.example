# ============================================================
#  Society Maintenance Tracker — Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit the .env file to version control.
# ============================================================

# ---- Application -----------------------------------------------
NODE_ENV=development
PORT=5000

# URL of the React client (used for CORS whitelist)
CLIENT_URL=http://localhost:5173

# ---- Database --------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local Docker:  postgresql://society_user:society_password@localhost:5432/society_maintenance
# Production:    obtain from Neon dashboard → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ---- JWT -------------------------------------------------------
# Minimum 32 characters — use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ---- Cloudinary ------------------------------------------------
# Obtain from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Resend (Email) -------------------------------------------
# Obtain from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
# Must be a verified sender domain in Resend
FROM_EMAIL=noreply@yourdomain.com

# ---- Frontend (Vite) ------------------------------------------
# Set to the deployed backend URL for production builds
VITE_API_URL=http://localhost:5000/api

# ---- Groq AI ---------------------------------------------------
# Obtain from: https://console.groq.com → API Keys
# Used by POST /api/ai/analyze-complaint to power the complaint assistant
GROQ_API_KEY=gsk_your_groq_api_key_here
